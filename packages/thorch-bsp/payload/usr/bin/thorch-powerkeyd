#!/usr/bin/env python3
import os
import select
import struct
import subprocess
import time

EV_KEY = 1
EV_SW = 5
KEY_POWER = 116
SW_LID = 0
DEVICE_NAMES = {"pmic_pwrkey", "gpio-keys"}
DEBOUNCE_SECONDS = 0.4


def input_devices():
    devices = []
    for entry in sorted(os.listdir("/sys/class/input")):
        if not entry.startswith("event"):
            continue
        try:
            with open(f"/sys/class/input/{entry}/device/name", "r", encoding="utf-8") as f:
                name = f.read().strip()
        except OSError:
            continue
        if name in DEVICE_NAMES:
            devices.append((f"/dev/input/{entry}", name))
    return devices


def run_fake_suspend(action):
    subprocess.run(["/usr/bin/thorch-fake-suspend", action], check=False)


def main():
    fmt = "llHHi"
    size = struct.calcsize(fmt)
    last_power = 0.0

    while True:
        opened = []
        for path, name in input_devices():
            try:
                opened.append((open(path, "rb", buffering=0), name))
            except OSError:
                pass

        if not opened:
            time.sleep(1)
            continue

        try:
            poller = select.poll()
            by_fd = {}
            for fobj, name in opened:
                poller.register(fobj, select.POLLIN)
                by_fd[fobj.fileno()] = (fobj, name)

            while True:
                for fd, _ in poller.poll(1000):
                    fobj, _ = by_fd[fd]
                    data = fobj.read(size)
                    if len(data) != size:
                        raise OSError("short input read")
                    _, _, etype, code, value = struct.unpack(fmt, data)
                    if etype == EV_KEY and code == KEY_POWER and value == 1:
                        now = time.monotonic()
                        if now - last_power >= DEBOUNCE_SECONDS:
                            last_power = now
                            run_fake_suspend("toggle")
                    elif etype == EV_SW and code == SW_LID:
                        run_fake_suspend("suspend" if value == 1 else "resume")
        except OSError:
            pass
        finally:
            for fobj, _ in opened:
                try:
                    fobj.close()
                except OSError:
                    pass
            time.sleep(1)


if __name__ == "__main__":
    main()
